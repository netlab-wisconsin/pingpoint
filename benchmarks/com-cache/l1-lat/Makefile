BASE_DIR := $(shell pwd)
BIN_DIR := $(BASE_DIR)/bin

HIPOPTS = --amdgpu-target=gfx942
HIP_PATH = /opt/rocm-7.1.0
CC := $(HIP_PATH)/bin/hipcc

ARRAY_SIZE_4096 = 4096

REPEAT_TIMES_4096 = 4096
REPEAT_TIMES_8192 = 8192

STRIDE_2 = 2
STRIDE_4 = 4
STRIDE_8 = 8
STRIDE_16 = 16
STRIDE_32 = 32
STRIDE_64 = 64

L1_LAT_SRC = l1_lat.cpp
L1_LAT_TARGET_1 = l1_lat_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)
L1_LAT_TARGET_2 = l1_lat_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)

L1_LAT_FOCUSED_SRC = l1_lat_focused.cpp
L1_LAT_FOCUSED_TARGET_1 = l1_lat_focused_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)
L1_LAT_FOCUSED_TARGET_2 = l1_lat_focused_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)

L1_LAT_COALESCED_SRC = l1_lat_coalesced.cpp
L1_LAT_COALESCED_TARGET_1 = l1_lat_coal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)
L1_LAT_COALESCED_TARGET_2 = l1_lat_coal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)

L1_LAT_UNCOALESCED_SRC = l1_lat_uncoalesced.cpp
L1_LAT_UNCOALESCED_TARGET_1 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)_s_$(STRIDE_2)
L1_LAT_UNCOALESCED_TARGET_2 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)_s_$(STRIDE_2)
L1_LAT_UNCOALESCED_TARGET_3 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)_s_$(STRIDE_4)
L1_LAT_UNCOALESCED_TARGET_4 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)_s_$(STRIDE_4)
L1_LAT_UNCOALESCED_TARGET_5 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)_s_$(STRIDE_8)
L1_LAT_UNCOALESCED_TARGET_6 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)_s_$(STRIDE_8)
L1_LAT_UNCOALESCED_TARGET_7 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)_s_$(STRIDE_16)
L1_LAT_UNCOALESCED_TARGET_8 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)_s_$(STRIDE_16)
L1_LAT_UNCOALESCED_TARGET_9 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)_s_$(STRIDE_32)
L1_LAT_UNCOALESCED_TARGET_10 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)_s_$(STRIDE_32)
L1_LAT_UNCOALESCED_TARGET_11 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_4096)_s_$(STRIDE_64)
L1_LAT_UNCOALESCED_TARGET_12 = l1_lat_uncoal_a_$(ARRAY_SIZE_4096)_r_$(REPEAT_TIMES_8192)_s_$(STRIDE_64)


all: $(BIN_DIR)/$(L1_LAT_TARGET_1) $(BIN_DIR)/$(L1_LAT_TARGET_2) \
     $(BIN_DIR)/$(L1_LAT_FOCUSED_TARGET_1) $(BIN_DIR)/$(L1_LAT_FOCUSED_TARGET_2) \
     $(BIN_DIR)/$(L1_LAT_COALESCED_TARGET_1) $(BIN_DIR)/$(L1_LAT_COALESCED_TARGET_2) \
     $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_1) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_2) \
	 $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_3) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_4) \
	 $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_5) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_6) \
	 $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_7) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_8) \
	 $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_9) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_10) \
	 $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_11) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_12)

$(BIN_DIR)/$(L1_LAT_TARGET_1): $(L1_LAT_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) $< -o $@

$(BIN_DIR)/$(L1_LAT_TARGET_2): $(L1_LAT_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) $< -o $@

$(BIN_DIR)/$(L1_LAT_FOCUSED_TARGET_1): $(L1_LAT_FOCUSED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) $< -o $@

$(BIN_DIR)/$(L1_LAT_FOCUSED_TARGET_2): $(L1_LAT_FOCUSED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) $< -o $@

$(BIN_DIR)/$(L1_LAT_COALESCED_TARGET_1): $(L1_LAT_COALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) $< -o $@

$(BIN_DIR)/$(L1_LAT_COALESCED_TARGET_2): $(L1_LAT_COALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_1): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) -DSTRIDE=$(STRIDE_2) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_2): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) -DSTRIDE=$(STRIDE_2) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_3): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) -DSTRIDE=$(STRIDE_4) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_4): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) -DSTRIDE=$(STRIDE_4) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_5): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) -DSTRIDE=$(STRIDE_8) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_6): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) -DSTRIDE=$(STRIDE_8) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_7): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) -DSTRIDE=$(STRIDE_16) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_8): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) -DSTRIDE=$(STRIDE_16) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_9): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) -DSTRIDE=$(STRIDE_32) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_10): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) -DSTRIDE=$(STRIDE_32) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_11): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_4096) -DSTRIDE=$(STRIDE_64) $< -o $@

$(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_12): $(L1_LAT_UNCOALESCED_SRC)
	$(CC) $(HIPOPTS) -DARRAY_SIZE=$(ARRAY_SIZE_4096) -DREPEAT_TIMES=$(REPEAT_TIMES_8192) -DSTRIDE=$(STRIDE_64) $< -o $@

clean:
	rm -f $(BIN_DIR)/$(L1_LAT_TARGET_1) $(BIN_DIR)/$(L1_LAT_TARGET_2) \
		  $(BIN_DIR)/$(L1_LAT_FOCUSED_TARGET_1) $(BIN_DIR)/$(L1_LAT_FOCUSED_TARGET_2) \
		  $(BIN_DIR)/$(L1_LAT_COALESCED_TARGET_1) $(BIN_DIR)/$(L1_LAT_COALESCED_TARGET_2) \
		  $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_1) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_2) \
		  $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_3) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_4) \
		  $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_5) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_6) \
		  $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_7) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_8) \
		  $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_9) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_10) \
		  $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_11) $(BIN_DIR)/$(L1_LAT_UNCOALESCED_TARGET_12)